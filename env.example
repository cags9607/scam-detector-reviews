# Hugging Face model loading
REVIEW_CLASSIFIER_HF_REPO_ID=Trinotrotolueno/review-scam-adapters
REVIEW_CLASSIFIER_SUBFOLDER=
REVIEW_CLASSIFIER_HF_TOKEN=

# Inference
REVIEW_CLASSIFIER_MAX_LENGTH=512
REVIEW_CLASSIFIER_NO_4BIT=0

# Cache policy:
# keep              -> keep loaded model resident across queue loops
# unload_after_call -> clear after each predict_records call
REVIEW_CLASSIFIER_CACHE_POLICY=keep

# Output shape
REVIEW_CLASSIFIER_INCLUDE_PROBABILITIES=0
REVIEW_CLASSIFIER_INCLUDE_LABEL_IDS=0
REVIEW_CLASSIFIER_OVERWRITE_PREDICTION_ID=0

# One-word review mapping
REVIEW_CLASSIFIER_APPLY_ONE_WORD_MAPPING=1
REVIEW_CLASSIFIER_FORCE_UNKNOWN_SINGLE_WORD_CLEAN=1

# Queue identity behavior
REVIEW_CLASSIFIER_REQUIRE_REVIEW_ID=1
REVIEW_CLASSIFIER_DUPLICATE_REVIEW_ID_POLICY=error

# Queue worker
QUEUE_URL=https://deepsee-queue.herokuapp.com/exchange-batch
QUEUE_API_KEY=
QUEUE_KEY=REVIEW_SCAM_CLASSIFIER_PLACEHOLDER
BATCH_SIZE=8
EMPTY_QUEUE_SLEEP_SECONDS=60
